PORT=7788
OPENAPI_ENABLE=false
NODE_ENV=production

# AUTH_TYPE: 0 disabled; 1 fixed token; 2 timestamp token.
AUTH_TYPE=0
AUTH_KEY=

# Detect
DETECT_MODEL_PATH=models/detect.onnx

# OCR
OCR_MODEL_PATH=models/ocr.onnx
OCR_CHARSET_PATH=models/ocr.json
OCR_CHARSET_RANGES=

# Rotate
ROTATE_MODEL_PATH=models/rotate.onnx

# OpenAI
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_OCR_MODEL=PaddleOCR-VL-1.6
OPENAI_MODEL=gpt-5.5
