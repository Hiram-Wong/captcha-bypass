RUN_MODE=server
NODE_ENV=production
# LOG_LEVEL: silly | debug | info | warn | error, default: info
LOG_LEVEL=warn

# SERVER
PORT=7788
OPENAPI_ENABLE=false

# AUTH_TYPE: 0 disabled; 1 fixed token; 2 timestamp token.
AUTH_TYPE=0
AUTH_KEY=

# Detect
DETECT_MODEL_PATH=models/detect.onnx
DETECT_SHAPE=[3,416,416]
DETECT_MEAN=[0,0,0]
DETECT_STD=[1,1,1]

# OCR
OCR_MODEL_PATH=models/ocr_ppv5-cn.onnx # ppocr: ocr_ppv5-cn.onnx / ddddocr: ocr_dddd.onnx
OCR_CHARSET_PATH=models/ocr_ppv5-cn.json # ppocr: ocr_ppv5-cn.json / ddddocr: ocr_dddd.json
OCR_CHARSET_RANGES=
OCR_SHAPE=[3,48,320] # ppocr: [3,48,320] / ddddocr: [1,64,0]
OCR_MEAN=0.5 # ppocr: 0.5 / ddddocr: 0.5
OCR_STD=0.5 # ppocr: 0.5 / ddddocr: 0.5
OCR_CTC_LAYOUT=ntc # ppocr: ntc / ddddocr: tnc

# Rotate
ROTATE_MODEL_PATH=models/rotate.onnx
ROTATE_SHAPE=[3,224,224]
ROTATE_MEAN=[0.485,0.456,0.406]
ROTATE_STD=[0.229,0.224,0.225]

# OpenAI
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_OCR_MODEL=PaddleOCR-VL-1.6
OPENAI_MODEL=gpt-5.5
