{
  "name": "captcha-bypass",
  "version": "1.0.9",
  "private": true,
  "description": "Captcha bypass service using OCR technology.",
  "type": "module",
  "main": "dist/index.js",
  "author": {
    "name": "Hiram-Wong",
    "email": "admin@catni.cn"
  },
  "license": "MIT",
  "homepage": "https://github.com/Hiram-Wong/captcha-bypass",
  "scripts": {
    "format": "bunx prettier --write src scripts",
    "dev": "bun --watch src/index.ts",
    "npmcheck": "ncu -u",
    "typecheck": "tsc --noEmit",
    "build": "bun scripts/build.js",
    "build:win": "bun scripts/build.js --platform win32",
    "build:win:x64": "bun scripts/build.js --platform win32 --arch x64",
    "build:win:arm64": "bun scripts/build.js --platform win32 --arch arm64",
    "build:mac": "bun scripts/build.js --platform darwin",
    "build:mac:x64": "bun scripts/build.js --platform darwin --arch x64",
    "build:mac:arm64": "bun scripts/build.js --platform darwin --arch arm64",
    "build:linux": "bun scripts/build.js --platform linux",
    "build:linux:x64": "bun scripts/build.js --platform linux --arch x64",
    "build:linux:arm64": "bun scripts/build.js --platform linux --arch arm64",
    "generate:token": "bun run ./scripts/generate-token.js"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.1",
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@techstark/opencv-js": "^5.0.0-release.1",
    "ai": "^7.0.4",
    "dateformat": "^5.0.3",
    "dotenv": "^17.4.2",
    "nanoid": "^5.1.16",
    "elysia": "^1.4.29",
    "jimp": "^1.6.1",
    "onnxruntime-web": "^1.27.0",
    "rotating-file-stream": "^3.2.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/dateformat": "^5.0.3",
    "npm-check-updates": "^22.2.8",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.14"
}
